# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org/

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ Files
[*.{cpp,hpp,h,c,cc,cxx,h++,hxx}]
indent_style = space
indent_size = 2
max_line_length = 100

# Python Files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# CMake Files
[CMakeLists.txt]
indent_style = space
indent_size = 2

# JSON Files
[*.json]
indent_style = space
indent_size = 2

# YAML Files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown Files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Shell Scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Windows Batch Scripts
[*.{bat,cmd}]
indent_style = space
indent_size = 2
end_of_line = crlf
