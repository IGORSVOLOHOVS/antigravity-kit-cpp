{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Python: Pytest",
            "type": "shell",
            "command": "uv",
            "args": ["run", "pytest"],
            "group": "test",
            "problemMatcher": [],
            "detail": "Run tests using Pytest."
        },
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Configure project with CMake."
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "-j",
                "$(nproc)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the project using all available cores."
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "build/*"
            ],
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "detail": "Remove everything in the build directory."
        },
        {
            "label": "CMake: Test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure",
                "-j",
                "$(nproc)"
            ],
            "group": "test",
            "problemMatcher": [],
            "detail": "Run all tests using CTest."
        },
        {
            "label": "Conan: Install",
            "type": "shell",
            "command": "conan",
            "args": [
                "install",
                ".",
                "--output-folder=build",
                "--build=missing"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Install project dependencies using Conan 2.0."
        },
        {
            "label": "CMake: Coverage",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "all",
                "&&",
                "ctest",
                "--test-dir",
                "build",
                "&&",
                "gcovr",
                "-r",
                ".",
                "--html",
                "--html-details",
                "-o",
                "build/coverage.html"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Run tests and generate coverage report (requires gcovr)."
        },
        {
            "label": "Doxygen: Generate",
            "type": "shell",
            "command": "doxygen",
            "args": [
                "Doxyfile"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Generate documentation using Doxygen."
        },
        {
            "label": "Verify All (Format, Build, Lint, Test)",
            "type": "shell",
            "command": "python3",
            "args": [
                ".agent/scripts/verify_all.py"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [],
            "detail": "Run complete validation pipeline (format check, build, lint, test, coverage)."
        },
        {
            "label": "Generate HEARTBEAT.md",
            "type": "shell",
            "command": "python3",
            "args": [
                ".agent/scripts/generate_heartbeat.py",
                "--output",
                ".agent/HEARTBEAT.md"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Generate project health metrics report."
        },
        {
            "label": "Format C++ (clang-format)",
            "type": "shell",
            "command": "clang-format",
            "args": [
                "-i",
                "-style=file",
                "${file}"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Format current C++ file using clang-format."
        },
        {
            "label": "Lint C++ (clang-tidy)",
            "type": "shell",
            "command": "clang-tidy",
            "args": [
                "${file}",
                "--",
                "-std=c++23"
            ],
            "group": "none",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Run clang-tidy analysis on current C++ file."
        },
        {
            "label": "Python: Format (ruff)",
            "type": "shell",
            "command": "python3",
            "args": [
                "-m",
                "ruff",
                "format",
                "${file}"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Format current Python file using ruff."
        },
        {
            "label": "Python: Lint (ruff)",
            "type": "shell",
            "command": "python3",
            "args": [
                "-m",
                "ruff",
                "check",
                "${file}",
                "--fix"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Lint and fix current Python file using ruff."
        },
        {
            "label": "Python: Type Check (mypy)",
            "type": "shell",
            "command": "python3",
            "args": [
                "-m",
                "mypy",
                "--strict",
                "${file}"
            ],
            "group": "none",
            "problemMatcher": [],
            "detail": "Type check current Python file using mypy (strict mode)."
        }
    ]
}
